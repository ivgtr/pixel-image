{
  "name": "pixel-image",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w \"./src/**/*.{js,jsx,ts,tsx,css,scss}\"  \"./*.{js,jsx,ts,tsx,css,scss}\"",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx,css,scss}\" \"./tests/**/*.{js,jsx,ts,tsx}\"",
    "lint:web": "eslint \"./src/**/*.{jsx,tsx,css,scss}\"",
    "lint:api": "eslint \"./src/**/*.{js,ts}\"",
    "audit": "npm audit --omit=dev",
    "proxy": "ngrok http 3000"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "canvas": "3.2.3",
    "classnames": "2.5.1",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.15",
    "prettier": "3.8.5",
    "sass": "1.101.0",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
